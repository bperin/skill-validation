# Copy to infra/config.env. Never commit config.env or secret value files.
PROJECT_ID=
REGION=us-central1
SERVICE_NAME=project-validation
ARTIFACT_REPOSITORY=project-attest
IMAGE_NAME=project-validation
RUNTIME_SERVICE_ACCOUNT=project-validation-runtime

# Private Cloud SQL ledger.
NETWORK_NAME=project-attest
SUBNET_NAME=project-attest-run
SUBNET_RANGE=10.42.0.0/24
PRIVATE_SERVICE_RANGE=project-attest-google-managed-services
CLOUD_SQL_INSTANCE=project-validation-ledger
CLOUD_SQL_DATABASE=attestations
CLOUD_SQL_USER=attestation_writer
CLOUD_SQL_TIER=db-custom-1-3840
CLOUD_SQL_AVAILABILITY_TYPE=ZONAL
CLOUD_SQL_DISK_SIZE_GB=20
DATABASE_URL_SECRET=project-validation-database-url
# Set one of these only while provisioning credentials.
DATABASE_PASSWORD_FILE=
DATABASE_URL_FILE=
ROTATE_DATABASE_CREDENTIALS=false

# Service-to-service caller token.
ISSUER_TOKEN_SECRET=project-validation-issuer-token
ISSUER_TOKEN_FILE=

# Off-chain attestation signer (ECDSA P-256).
KMS_LOCATION=us-central1
KMS_KEY_RING=project-attestation
ATTESTATION_KMS_KEY=attestation-signing
ATTESTATION_KMS_KEY_VERSION_ID=1
ATTESTATION_ISSUER=
VERIFICATION_BASE_URL=

# Public ZK-proof anchor. The RPC URL is a secret because hosted endpoints often
# contain credentials. The publisher key remains non-exportable in Cloud KMS.
EVM_RPC_URL_SECRET=project-validation-evm-rpc-url
EVM_RPC_URL_FILE=
EVM_CHAIN_ID=
EVM_VERIFIER_CONTRACT=
EVM_PUBLISHER_ADDRESS=
EVM_PUBLISHER_KMS_KEY=evm-publisher-signing
EVM_PUBLISHER_KMS_KEY_VERSION_ID=1

# Cloud Run sizing.
MIN_INSTANCES=0
MAX_INSTANCES=10
CONCURRENCY=20
CPU=1
MEMORY=512Mi
TIMEOUT=60s
