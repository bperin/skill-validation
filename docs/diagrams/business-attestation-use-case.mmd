flowchart TB
    subgraph Earn[Earn the skill proof]
        direction LR
        Builder[Developer completes<br/>a real project]:::person
        Evidence[Repository, commit,<br/>build, or deployment]:::evidence
        Review[Issuer checks work<br/>against a skill policy]:::issuer
        Credential[Issuer signs one<br/>portable skill record]:::credential
        Builder --> Evidence --> Review --> Credential
    end

    subgraph Use[Recruiter and hiring-system verification loop]
        direction LR
        Display[Repository, portfolio,<br/>profile, or hiring system]:::surface
        Recruiter[Recruiter or automated<br/>hiring system reads proof]:::person
        Verify[Check issuer signature,<br/>evidence, and status]:::verify
        Result{Use current verified<br/>skill in the decision}:::result
        Display --> Recruiter --> Verify --> Result
    end

    Registry[(Issuer-published status or<br/>public registry: active, revoked, updated)]:::chain
    Policy[New policy or evidence]:::history

    Earn --> Use
    Earn --> Registry --> Use
    Policy --> Registry

    classDef person fill:#f1eaff,stroke:#6941c6,color:#26164a,stroke-width:1.5px;
    classDef evidence fill:#e8f1ff,stroke:#2457a6,color:#10213a,stroke-width:1.5px;
    classDef issuer fill:#eaf8f1,stroke:#238558,color:#123c2a,stroke-width:1.5px;
    classDef credential fill:#dff7ec,stroke:#167a4a,color:#103a26,stroke-width:2px;
    classDef surface fill:#edf2f7,stroke:#4a5568,color:#1a202c,stroke-width:1.5px;
    classDef chain fill:#fff0d8,stroke:#b45f06,color:#472400,stroke-width:2px;
    classDef verify fill:#fff5dc,stroke:#a46b08,color:#4a3100,stroke-width:1.5px;
    classDef result fill:#d9f99d,stroke:#4d7c0f,color:#1a2e05,stroke-width:2px;
    classDef history fill:#fee8e7,stroke:#b42318,color:#5d0e08,stroke-width:1.5px;
